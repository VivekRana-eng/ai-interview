# ─── APP MODE ────────────────────────────────────────
# 'mock' = Phase 0 demo (Supabase + mocked AI)
# 'live' = Phase 1 production (FastAPI + real AI)
NEXT_PUBLIC_APP_MODE=mock

# ─── SUPABASE (Phase 0) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only, never expose

# ─── FASTAPI BACKEND (Phase 1 only) ──────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── AI — Groq (Phase 1 only) ────────────────────────
GROQ_API_KEY=gsk_...

# ─── AI — OpenRouter fallback (Phase 1 only) ─────────
OPENROUTER_API_KEY=sk-or-...

# ─── AI — HuggingFace embeddings (Phase 1 only) ──────
HF_API_KEY=hf_...

# ─── AUTH (Phase 1 only) ─────────────────────────────
JWT_SECRET=minimum-32-character-random-string-here
JWT_EXPIRE_MINUTES=60

# ─── EMAIL SMTP (Phase 1 only) ───────────────────────
# In Phase 0: emails are console.log'd only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# ─── DATABASE PostgreSQL (Phase 1 only) ──────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/selection_db

# ─── APP CONFIG ───────────────────────────────────────
SCREENING_THRESHOLD=55
CORS_ORIGINS=http://localhost:3000
